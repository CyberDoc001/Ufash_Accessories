# Auto detect text files and normalize line endings to LF
* text=auto

# Python
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.exe binary

# Data files
*.db binary
*.sqlite binary
*.sqlite3 binary
*.csv text
*.json text
*.yml text
*.yaml text

# Archives
*.zip binary
*.tar binary
*.gz binary
*.rar binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg text
